# =============================================================================
# Meridian — copy to .env and fill in. Backend loads APP_* from pydantic-settings.
# Never commit .env. See setup.md for how to obtain each value.
# =============================================================================

# ─── PostgreSQL (required) ─────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
#
# Docker Compose (Postgres runs in Docker): HOST must be the service name `postgres` and must
# match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB. URL-encode special characters in PASSWORD.
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/resume_builder

# ─── Docker Compose — Postgres container (used by compose; must match APP_DATABASE_URL) ───
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=resume_builder
# Publish Postgres to the host for GUI clients (change if port 5432 is already in use)
POSTGRES_HOST_PORT=5432
# API container → host port mapping
HOST_API_PORT=8000

# ─── Container process — uvicorn bind (not APP_*; used by docker/entrypoint.sh) ─
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# Local Python only (uvicorn on the host): use localhost and a DB you created locally, e.g.
# APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/resume_builder

APP_DEBUG=false

# Browser origins allowed to call the API (comma-separated). Match your Vite dev URL or production site.
# Use * only for quick open tests (wildcard disables credential mode per CORS rules).
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── OpenAI (required for tailoring + match scoring) ───────────────────────
# Get key: https://platform.openai.com/api-keys
APP_OPENAI_API_KEY=
APP_OPENAI_MODEL=gpt-4o

# ─── JWT auth ─────────────────────────────────────────────────────────────
# Generate secret: openssl rand -hex 32
APP_JWT_SECRET=change-me-to-a-long-random-string
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Admin users ───────────────────────────────────────────────────────────
# Comma-separated emails → users get is_admin=true on register/login sync
APP_ADMIN_EMAILS=

# ─── Scheduled job sync (APScheduler, UTC cron: min hour dom mon dow) ─────
APP_JOB_SYNC_CRON=0 6 * * *

# Omit listings with posted_at older than this (days). 0 = disable age filter.
APP_JOB_LISTING_MAX_AGE_DAYS=90

# ─── PRIMARY — Adzuna Jobs API (broad job search) ──────────────────────────
# Sign up: https://developer.adzuna.com/signup — APP_ID and APP_KEY in dashboard.
# Country path segment: gb, us, de, … (see Adzuna docs for supported markets).
APP_ADZUNA_APP_ID=
APP_ADZUNA_APP_KEY=
APP_ADZUNA_COUNTRY=gb
APP_ADZUNA_RESULTS_PER_PAGE=25
APP_ADZUNA_MAX_SEARCH_PAIRS=6

# ─── PRIMARY — Jooble REST API ─────────────────────────────────────────────
# Register: https://jooble.org/api/about — API key used in POST /api/{key}
APP_JOOBLE_API_KEY=
APP_JOOBLE_PAGE=1
APP_JOOBLE_RADIUS_KM=25

# ─── SECONDARY — LinkedIn Talent — YOUR org’s job postings (REST) ─────────
# Partner / Talent Solutions access only. Not a public “search all LinkedIn jobs” API.
# Overview: https://learn.microsoft.com/en-us/linkedin/talent/job-postings/
# Create a LinkedIn Developer app → OAuth 2.0 → token with job-posting scopes.
# Organization URN: often urn:li:organization:NUMERIC_ID (from company page / API).
APP_LINKEDIN_ACCESS_TOKEN=
APP_LINKEDIN_ORGANIZATION_URN=
APP_LINKEDIN_API_VERSION=202411

# ─── SECONDARY — XING E-Recruiting — YOUR vendor postings ───────────────────
# Requires approved XING app + E-Recruiting contract.
# Start: https://dev.xing.com/partners/job_integration
APP_XING_ACCESS_TOKEN=
APP_XING_API_BASE=https://api.xing.com

# ─── SECONDARY — Naukri Gulf — HTTPS XML or RSS job feed ───────────────────
# No public job-search API; use the XML/RSS URL InfoEdge gives your organization.
APP_NAUKRI_GULF_XML_FEED_URL=

# ─── IO careers module — allowlisted official RSS (comma-separated) ────────
# Not mixed with JobListing / Adzuna sync. Defaults: UN Careers, UNDP, ReliefWeb.
# Clear to disable defaults; add/remove URLs per deployment. Invalid entries are skipped.
#
# Other UN system / IO agencies (IAEA, OPCW, UNICEF, WHO, ILO, UNICC, …):
# - There is usually no one “official RSS for all vacancies” in public docs. Many sites use
#   Taleo, PageUp, Workday, Talent Soft, etc., and expose RSS only from the job search UI
#   (e.g. “RSS”, “Create RSS feed”, “Subscribe”) — copy that exact HTTPS URL into this list.
# - Examples to verify on the live careers site (URLs change): WHO (Taleo-style search RSS),
#   UNICEF PageUp RSS, IAEA Taleo search RSS, OPCW Talent Soft “all vacancies” RSS hub.
# - Some orgs (e.g. ILO jobs.ilo.org) emphasize email alerts over a public vacancy RSS — use
#   alerts/curation/HTML fetch only where ToS allows if no RSS exists.
# - Comma-separated list: one sync run polls every URL (admin “Sync IO feeds” + scheduler).
# - Prefer RSS where each <item> links to a single vacancy (e.g. …/vacancies/<id>). Feeds that
#   only link to UNjobs “/New/N” listing pages rely on optional HTML expansion (often blocked by
#   Cloudflare from servers); use rss.app or UNjobs feeds that emit per-vacancy items when possible.
APP_IO_JOB_RSS_URLS=https://careers.un.org/jobfeed,https://jobs.undp.org/cj_rss_feed.cfm,https://reliefweb.int/jobs/rss.xml,https://rss.app/feeds/7TLdQuNxARWjD3bs.xml
# UTC cron for periodic RSS poll (5 fields). Empty = disable scheduled IO ingest.
APP_IO_JOB_RSS_CRON=15 * * * *
APP_IO_JOB_HTTP_TIMEOUT_SEC=45
# UNjobs.org /New/N hub pages: expand to /vacancies/<id> when the HTML response contains links.
# Set false to drop hub-only items without fetching. Max caps vacancies per hub per run.
APP_IO_JOB_UNJOBS_EXPAND_HUBS=true
APP_IO_JOB_UNJOBS_MAX_VACANCIES_PER_HUB=200

# ─── Storage (paths relative to project root unless absolute) ──────────────
APP_TEMPLATES_DIR=storage/templates
APP_OUTPUT_DIR=storage/output
APP_RESUMES_DIR=storage/resumes

# ─── Frontend (Vite — exposed to browser; no APP_ prefix) ────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8000
