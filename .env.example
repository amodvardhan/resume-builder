# ─── Backend (prefix: APP_) ──────────────────────────────────────────────
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/resume_builder
APP_DEBUG=false
APP_OPENAI_API_KEY=sk-...
APP_OPENAI_MODEL=gpt-4o
APP_JWT_SECRET=change-me-to-a-random-64-char-string
APP_CRAWL_CRON=0 6 * * *
# Optional: required for Adzuna crawl source (developer.adzuna.com)
APP_ADZUNA_APP_ID=
APP_ADZUNA_APP_KEY=
APP_TEMPLATES_DIR=storage/templates
APP_OUTPUT_DIR=storage/output

# ─── Frontend (Vite) ────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
