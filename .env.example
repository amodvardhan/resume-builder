# =============================================================================
# Meridian — copy to .env and fill in. Backend loads APP_* from pydantic-settings.
# Never commit .env. See setup.md for how to obtain each value.
# =============================================================================

# ─── PostgreSQL (required) ─────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
# Local: create DB first, e.g. `createdb resume_builder` or Docker Postgres.
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/resume_builder

APP_DEBUG=false

# ─── OpenAI (required for tailoring + match scoring) ───────────────────────
# Get key: https://platform.openai.com/api-keys
APP_OPENAI_API_KEY=
APP_OPENAI_MODEL=gpt-4o

# ─── JWT auth ─────────────────────────────────────────────────────────────
# Generate secret: openssl rand -hex 32
APP_JWT_SECRET=change-me-to-a-long-random-string
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Admin users ───────────────────────────────────────────────────────────
# Comma-separated emails → users get is_admin=true on register/login sync
APP_ADMIN_EMAILS=

# ─── Scheduled job sync (APScheduler, UTC cron: min hour dom mon dow) ─────
APP_JOB_SYNC_CRON=0 6 * * *

# Omit listings with posted_at older than this (days). 0 = disable age filter.
APP_JOB_LISTING_MAX_AGE_DAYS=90

# ─── PRIMARY — Adzuna Jobs API (broad job search) ──────────────────────────
# Sign up: https://developer.adzuna.com/signup — APP_ID and APP_KEY in dashboard.
# Country path segment: gb, us, de, … (see Adzuna docs for supported markets).
APP_ADZUNA_APP_ID=
APP_ADZUNA_APP_KEY=
APP_ADZUNA_COUNTRY=gb
APP_ADZUNA_RESULTS_PER_PAGE=25
APP_ADZUNA_MAX_SEARCH_PAIRS=6

# ─── PRIMARY — Jooble REST API ─────────────────────────────────────────────
# Register: https://jooble.org/api/about — API key used in POST /api/{key}
APP_JOOBLE_API_KEY=
APP_JOOBLE_PAGE=1
APP_JOOBLE_RADIUS_KM=25

# ─── SECONDARY — LinkedIn Talent — YOUR org’s job postings (REST) ─────────
# Partner / Talent Solutions access only. Not a public “search all LinkedIn jobs” API.
# Overview: https://learn.microsoft.com/en-us/linkedin/talent/job-postings/
# Create a LinkedIn Developer app → OAuth 2.0 → token with job-posting scopes.
# Organization URN: often urn:li:organization:NUMERIC_ID (from company page / API).
APP_LINKEDIN_ACCESS_TOKEN=
APP_LINKEDIN_ORGANIZATION_URN=
APP_LINKEDIN_API_VERSION=202411

# ─── SECONDARY — XING E-Recruiting — YOUR vendor postings ───────────────────
# Requires approved XING app + E-Recruiting contract.
# Start: https://dev.xing.com/partners/job_integration
APP_XING_ACCESS_TOKEN=
APP_XING_API_BASE=https://api.xing.com

# ─── SECONDARY — Naukri Gulf — HTTPS XML or RSS job feed ───────────────────
# No public job-search API; use the XML/RSS URL InfoEdge gives your organization.
APP_NAUKRI_GULF_XML_FEED_URL=

# ─── Storage (paths relative to project root unless absolute) ──────────────
APP_TEMPLATES_DIR=storage/templates
APP_OUTPUT_DIR=storage/output
APP_RESUMES_DIR=storage/resumes

# ─── Frontend (Vite — exposed to browser; no APP_ prefix) ────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8000
